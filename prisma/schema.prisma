generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

enum Role {
  CUSTOMER
  ORGANIZER
  CHECKIN
  ADMIN
}

enum EventStatus {
  DRAFT
  PUBLISHED
}

enum SalesMode {
  INSTANT
  APPROVAL_REQUIRED
}

enum OrderStatus {
  PENDING
  PENDING_APPROVAL
  AWAITING_PAYMENT
  REJECTED
  PAID
  CANCELLED
}

enum TicketStatus {
  VALID
  USED
  CANCELLED
}

enum PriceMode {
  PER_SEAT
  WHOLE_TABLE
}

enum PricingMode {
  FIXED
  SCHEDULED
}

enum SeatingObjectType {
  TABLE
  ROUND_TABLE
  SOFA
  ROW
  ZONE
  STAGE
  BAR
  TEXT
}

enum SeatStatus {
  AVAILABLE
  RESERVED
  BLOCKED
}

model Organization {
  id        String   @id @default(cuid())
  name      String
  users     User[]
  events    Event[]
  createdAt DateTime @default(now())
}

model User {
  id             String        @id @default(cuid())
  name           String
  email          String        @unique
  role           Role
  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id])
  createdAt      DateTime      @default(now())
}

model Venue {
  id      String  @id @default(cuid())
  name    String
  city    String
  address String
  events  Event[]
}

model Event {
  id                   String           @id @default(cuid())
  slug                 String           @unique
  title                String
  description          String
  posterUrl            String
  startsAt             DateTime
  salesStart           DateTime
  salesEnd             DateTime
  status               EventStatus      @default(DRAFT)
  salesMode            SalesMode        @default(INSTANT)
  approvalInstructions String?
  mapEnabled           Boolean          @default(false)
  mapName              String?          @default("Основной зал")
  organizationId       String
  organization         Organization     @relation(fields: [organizationId], references: [id])
  venueId              String
  venue                Venue            @relation(fields: [venueId], references: [id])
  categories           TicketCategory[]
  zones                Zone[]
  orders               Order[]
  promoCodes           PromoCode[]
  referrals            Referral[]
  createdAt            DateTime         @default(now())
  updatedAt            DateTime         @updatedAt
}

model TicketCategory {
  id             String            @id @default(cuid())
  name           String
  description    String?
  priceMinor     Int
  pricingMode    PricingMode       @default(FIXED)
  currency       String            @default("ILS")
  capacity       Int
  sold           Int               @default(0)
  salesStart     DateTime?
  salesEnd       DateTime?
  minPerOrder    Int               @default(1)
  maxPerOrder    Int               @default(10)
  hidden         Boolean           @default(false)
  eventId        String
  event          Event             @relation(fields: [eventId], references: [id])
  tickets        Ticket[]
  seatingObjects Table[]
  priceTiers     TicketPriceTier[]

  @@unique([eventId, name])
}

model TicketPriceTier {
  id         String         @id @default(cuid())
  label      String
  priceMinor Int
  startsAt   DateTime
  endsAt     DateTime
  categoryId String
  category   TicketCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@index([categoryId, startsAt, endsAt])
}

model Zone {
  id      String  @id @default(cuid())
  name    String
  eventId String
  event   Event   @relation(fields: [eventId], references: [id])
  tables  Table[]

  @@unique([eventId, name])
}

model Table {
  id         String            @id @default(cuid())
  label      String
  seats      Int
  priceMinor Int
  priceMode  PriceMode         @default(WHOLE_TABLE)
  objectType SeatingObjectType @default(TABLE)
  x          Int               @default(20)
  y          Int               @default(20)
  rotation   Int               @default(0)
  width      Int               @default(120)
  height     Int               @default(80)
  reserved   Boolean           @default(false)
  zoneId     String
  zone       Zone              @relation(fields: [zoneId], references: [id])
  categoryId String?
  category   TicketCategory?   @relation(fields: [categoryId], references: [id])
  seatItems  Seat[]
  orderItems OrderItem[]

  @@unique([zoneId, label])
}

model Seat {
  id         String      @id @default(cuid())
  label      String
  position   Int
  status     SeatStatus  @default(AVAILABLE)
  tableId    String
  table      Table       @relation(fields: [tableId], references: [id], onDelete: Cascade)
  orderItems OrderItem[]

  @@unique([tableId, position])
}

model Order {
  id                String      @id @default(cuid())
  publicId          String      @unique
  idempotencyKey    String      @unique
  customerName      String
  customerEmail     String
  customerPhone     String
  totalMinor        Int
  currency          String      @default("ILS")
  status            OrderStatus @default(PAID)
  eligibilityAnswer String?
  reviewNote        String?
  reviewedAt        DateTime?
  paymentDueAt      DateTime?
  eventId           String
  event             Event       @relation(fields: [eventId], references: [id])
  items             OrderItem[]
  tickets           Ticket[]
  referralId        String?
  referral          Referral?   @relation(fields: [referralId], references: [id])
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt
}

model OrderItem {
  id             String  @id @default(cuid())
  quantity       Int
  unitPriceMinor Int
  categoryName   String
  orderId        String
  order          Order   @relation(fields: [orderId], references: [id])
  tableId        String?
  table          Table?  @relation(fields: [tableId], references: [id])
  seatId         String?
  seat           Seat?   @relation(fields: [seatId], references: [id])
}

model Ticket {
  id         String         @id @default(cuid())
  publicCode String         @unique
  status     TicketStatus   @default(VALID)
  holderName String
  categoryId String
  category   TicketCategory @relation(fields: [categoryId], references: [id])
  orderId    String
  order      Order          @relation(fields: [orderId], references: [id])
  scans      Scan[]
  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt
}

model Scan {
  id        String   @id @default(cuid())
  result    String
  scannedAt DateTime @default(now())
  ticketId  String?
  ticket    Ticket?  @relation(fields: [ticketId], references: [id])
}

model PromoCode {
  id              String  @id @default(cuid())
  code            String
  discountPercent Int
  active          Boolean @default(true)
  eventId         String
  event           Event   @relation(fields: [eventId], references: [id])

  @@unique([eventId, code])
}

model Referral {
  id      String  @id @default(cuid())
  code    String  @unique
  label   String
  eventId String
  event   Event   @relation(fields: [eventId], references: [id])
  orders  Order[]
}
