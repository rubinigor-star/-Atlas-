generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

enum Role {
  CUSTOMER
  ORGANIZER
  CHECKIN
  ADMIN
}

enum StaffRole {
  OWNER
  ADMIN
  EVENT_MANAGER
  APPROVER
  CHECKIN
  ANALYST
  CUSTOM
}

enum StaffPermission {
  EVENT_VIEW
  EVENT_MANAGE
  TICKET_MANAGE
  REQUEST_REVIEW
  ORDER_VIEW
  ORDER_MANAGE
  SCAN
  ANALYTICS_VIEW
  TEAM_MANAGE
  FINANCE_VIEW
}

enum EventStatus {
  DRAFT
  PUBLISHED
}

enum SalesMode {
  INSTANT
  APPROVAL_REQUIRED
}

enum OrderStatus {
  PENDING
  PENDING_APPROVAL
  AWAITING_PAYMENT
  REJECTED
  PAID
  CANCELLED
}

enum TicketStatus {
  VALID
  USED
  CANCELLED
}

enum PriceMode {
  PER_SEAT
  WHOLE_TABLE
}

enum PricingMode {
  FIXED
  SCHEDULED
}

enum SeatingObjectType {
  TABLE
  ROUND_TABLE
  SOFA
  ROW
  ZONE
  STAGE
  BAR
  TEXT
}

enum SeatStatus {
  AVAILABLE
  RESERVED
  BLOCKED
}

enum PromoterAllocationType {
  EVENT
  CATEGORY
  TABLE
}

enum GuestStatus {
  REGULAR
  VIP
  CELEBRITY
  BLACKLIST
  ORGANIZER
  ARTIST
}

model Organization {
  id        String         @id @default(cuid())
  name      String
  users     User[]
  events    Event[]
  promoters Promoter[]
  guests    GuestProfile[]
  auditLogs AuditLog[]
  createdAt DateTime       @default(now())
}

model User {
  id             String             @id @default(cuid())
  name           String
  email          String             @unique
  role           Role
  staffRole      StaffRole?         @default(CUSTOM)
  jobTitle       String?
  active         Boolean            @default(true)
  organizationId String?
  organization   Organization?      @relation(fields: [organizationId], references: [id])
  permissions    PermissionGrant[]
  eventAccess    EventStaffAccess[]
  auditLogs      AuditLog[]
  createdAt      DateTime           @default(now())
}

model Venue {
  id      String  @id @default(cuid())
  name    String
  city    String
  address String
  events  Event[]
}

model Event {
  id                   String             @id @default(cuid())
  slug                 String             @unique
  title                String
  description          String
  posterUrl            String
  startsAt             DateTime
  salesStart           DateTime
  salesEnd             DateTime
  status               EventStatus        @default(DRAFT)
  salesMode            SalesMode          @default(INSTANT)
  approvalInstructions String?
  mapEnabled           Boolean            @default(false)
  mapName              String?            @default("Основной зал")
  organizationId       String
  organization         Organization       @relation(fields: [organizationId], references: [id])
  venueId              String
  venue                Venue              @relation(fields: [venueId], references: [id])
  categories           TicketCategory[]
  zones                Zone[]
  orders               Order[]
  promoCodes           PromoCode[]
  referrals            Referral[]
  promoterLinks        PromoterLink[]
  staffAccess          EventStaffAccess[]
  ticketTemplate       TicketTemplate?
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt
}

model TicketTemplate {
  id              String   @id @default(cuid())
  name            String   @default("Основной билет")
  canvasJson      String
  backgroundColor String   @default("#081426")
  accentColor     String   @default("#FF5C45")
  textColor       String   @default("#FFFFFF")
  logoUrl         String?
  backgroundUrl   String?
  eventId         String   @unique
  event           Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model PermissionGrant {
  id         String          @id @default(cuid())
  permission StaffPermission
  userId     String
  user       User            @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, permission])
  @@index([userId])
}

model EventStaffAccess {
  id      String @id @default(cuid())
  userId  String
  user    User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  eventId String
  event   Event  @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@unique([userId, eventId])
  @@index([eventId])
}

model AuditLog {
  id             String       @id @default(cuid())
  action         String
  entityType     String
  entityId       String?
  summary        String
  metadata       String?
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  actorId        String?
  actor          User?        @relation(fields: [actorId], references: [id], onDelete: SetNull)
  createdAt      DateTime     @default(now())

  @@index([organizationId, createdAt])
  @@index([actorId])
}

model GuestProfile {
  id             String       @id @default(cuid())
  firstName      String
  lastName       String
  phone          String
  email          String
  birthDate      DateTime
  city           String
  facebook       String
  instagram      String
  status         GuestStatus  @default(REGULAR)
  notes          String?
  tags           String?
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  orders          Order[]
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  @@unique([organizationId, phone])
  @@index([organizationId, email])
  @@index([organizationId, birthDate])
  @@index([organizationId, status])
}

model TicketCategory {
  id             String            @id @default(cuid())
  name           String
  description    String?
  priceMinor     Int
  pricingMode    PricingMode       @default(FIXED)
  currency       String            @default("ILS")
  capacity       Int
  sold           Int               @default(0)
  salesStart     DateTime?
  salesEnd       DateTime?
  minPerOrder    Int               @default(1)
  maxPerOrder    Int               @default(10)
  hidden         Boolean           @default(false)
  colorHex       String            @default("#2563EB")
  eventId        String
  event          Event             @relation(fields: [eventId], references: [id])
  tickets        Ticket[]
  seatingObjects Table[]
  assignedSeats  Seat[]
  priceTiers     TicketPriceTier[]
  promoterLinks  PromoterLink[]

  @@unique([eventId, name])
}

model TicketPriceTier {
  id         String         @id @default(cuid())
  label      String
  priceMinor Int
  startsAt   DateTime
  endsAt     DateTime
  categoryId String
  category   TicketCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@index([categoryId, startsAt, endsAt])
}

model Zone {
  id      String  @id @default(cuid())
  name    String
  eventId String
  event   Event   @relation(fields: [eventId], references: [id])
  tables  Table[]

  @@unique([eventId, name])
}

model Table {
  id            String            @id @default(cuid())
  label         String
  seats         Int
  priceMinor    Int
  priceMode     PriceMode         @default(WHOLE_TABLE)
  objectType    SeatingObjectType @default(TABLE)
  x             Int               @default(20)
  y             Int               @default(20)
  rotation      Int               @default(0)
  width         Int               @default(120)
  height        Int               @default(80)
  reserved      Boolean           @default(false)
  zoneId        String
  zone          Zone              @relation(fields: [zoneId], references: [id])
  categoryId    String?
  category      TicketCategory?   @relation(fields: [categoryId], references: [id])
  seatItems     Seat[]
  orderItems    OrderItem[]
  promoterLinks PromoterLink[]

  @@unique([zoneId, label])
}

model Seat {
  id         String          @id @default(cuid())
  label      String
  position   Int
  status     SeatStatus      @default(AVAILABLE)
  tableId    String
  table      Table           @relation(fields: [tableId], references: [id], onDelete: Cascade)
  categoryId String?
  category   TicketCategory? @relation(fields: [categoryId], references: [id])
  orderItems OrderItem[]

  @@unique([tableId, position])
}

model Order {
  id                String        @id @default(cuid())
  publicId          String        @unique
  idempotencyKey    String        @unique
  customerName      String
  customerEmail     String
  customerPhone     String
  customerFirstName String?
  customerLastName  String?
  customerBirthDate DateTime?
  customerCity      String?
  customerFacebook  String?
  customerInstagram String?
  totalMinor        Int
  currency          String        @default("ILS")
  status            OrderStatus   @default(PAID)
  eligibilityAnswer String?
  reviewNote        String?
  reviewedAt        DateTime?
  paymentDueAt      DateTime?
  eventId           String
  event             Event         @relation(fields: [eventId], references: [id])
  guestId           String?
  guest             GuestProfile? @relation(fields: [guestId], references: [id], onDelete: SetNull)
  items             OrderItem[]
  tickets           Ticket[]
  referralId        String?
  referral          Referral?     @relation(fields: [referralId], references: [id])
  promoterLinkId    String?
  promoterLink      PromoterLink? @relation(fields: [promoterLinkId], references: [id])
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  @@index([guestId])
  @@index([customerPhone])
}

model OrderItem {
  id             String  @id @default(cuid())
  quantity       Int
  unitPriceMinor Int
  categoryName   String
  orderId        String
  order          Order   @relation(fields: [orderId], references: [id])
  tableId        String?
  table          Table?  @relation(fields: [tableId], references: [id])
  seatId         String?
  seat           Seat?   @relation(fields: [seatId], references: [id])
}

model Ticket {
  id                  String               @id @default(cuid())
  publicCode          String               @unique
  status              TicketStatus         @default(VALID)
  holderName          String
  categoryId          String
  category            TicketCategory       @relation(fields: [categoryId], references: [id])
  orderId             String
  order               Order                @relation(fields: [orderId], references: [id])
  scans               Scan[]
  walletSerial        String?              @unique
  walletAuthToken     String?              @unique
  walletUpdatedAt     DateTime             @default(now())
  walletRegistrations WalletRegistration[]
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
}

model WalletDevice {
  id                String               @id @default(cuid())
  libraryIdentifier String               @unique
  pushToken         String
  registrations     WalletRegistration[]
  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt
}

model WalletRegistration {
  id        String       @id @default(cuid())
  deviceId  String
  device    WalletDevice @relation(fields: [deviceId], references: [id], onDelete: Cascade)
  ticketId  String
  ticket    Ticket       @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  createdAt DateTime     @default(now())

  @@unique([deviceId, ticketId])
  @@index([ticketId])
}

model Scan {
  id        String   @id @default(cuid())
  result    String
  scannedAt DateTime @default(now())
  ticketId  String?
  ticket    Ticket?  @relation(fields: [ticketId], references: [id])
}

model PromoCode {
  id              String  @id @default(cuid())
  code            String
  discountPercent Int
  active          Boolean @default(true)
  eventId         String
  event           Event   @relation(fields: [eventId], references: [id])

  @@unique([eventId, code])
}

model Referral {
  id      String  @id @default(cuid())
  code    String  @unique
  label   String
  eventId String
  event   Event   @relation(fields: [eventId], references: [id])
  orders  Order[]
}

model Promoter {
  id                   String       @id @default(cuid())
  name                 String
  email                String?
  phone                String?
  active               Boolean      @default(true)
  defaultCommissionBps Int          @default(0)
  organizationId       String
  organization         Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  links                 PromoterLink[]
  createdAt             DateTime     @default(now())
  updatedAt             DateTime     @updatedAt

  @@unique([organizationId, name])
  @@index([organizationId, active])
}

model PromoterLink {
  id               String                  @id @default(cuid())
  code             String                  @unique
  label            String
  active           Boolean                 @default(true)
  allocationType   PromoterAllocationType  @default(EVENT)
  guestLimit       Int?
  maxPerOrder      Int                     @default(10)
  customPriceMinor Int?
  commissionBps    Int                     @default(0)
  exclusive        Boolean                 @default(true)
  startsAt         DateTime?
  endsAt           DateTime?
  eventId          String
  event            Event                   @relation(fields: [eventId], references: [id], onDelete: Cascade)
  promoterId       String
  promoter         Promoter                @relation(fields: [promoterId], references: [id], onDelete: Cascade)
  categoryId       String?
  category         TicketCategory?         @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  tableId          String?
  table            Table?                  @relation(fields: [tableId], references: [id], onDelete: SetNull)
  orders           Order[]
  visits           PromoterLinkVisit[]
  createdAt        DateTime                @default(now())
  updatedAt        DateTime                @updatedAt

  @@index([eventId, active])
  @@index([promoterId])
}

model PromoterLinkVisit {
  id          String       @id @default(cuid())
  sessionId   String
  source      String?
  utmSource   String?
  utmMedium   String?
  utmCampaign String?
  userAgent   String?
  linkId      String
  link        PromoterLink @relation(fields: [linkId], references: [id], onDelete: Cascade)
  createdAt   DateTime     @default(now())

  @@unique([linkId, sessionId])
  @@index([linkId, createdAt])
}
